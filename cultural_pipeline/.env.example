# Local development template (DO NOT commit real secrets)
# Copy to: cultural_pipeline/.env and fill in real values locally only
# Esta es una PLANTILLA. No vaciará secretos en git.

# --- MongoDB Atlas (web sink) ---
# Format example:
# mongodb+srv://<user>:<password>@<cluster>/?retryWrites=true&w=majority
MONGO_URI_WEB=
MONGO_DB_WEB=turislima_web
MONGO_COLL_WEB=eventos

# --- MongoDB Atlas (reco sink) ---
MONGO_URI_RECO=
MONGO_DB_RECO=turislima_reco
MONGO_COLL_RECO=eventos_vectors

# --- Lifecycle policy for stale docs ---
# true  -> hard delete docs not seen in full runs (recommended for weekly refresh)
# false -> only mark as inactive
MONGO_HARD_DELETE_STALE=true
# Number of consecutive full runs missed before hard delete (safety window)
MONGO_DELETE_AFTER_MISSED_FULL_RUNS=2

# --- Embeddings contract / guardrails ---
# Keep these stable after you create your Vector Search index.
ALLOW_OPENAI_FALLBACK=false
EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384

# --- Optional DeepSeek enrichment (NOT embeddings backend) ---
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_TEXT_MODEL=deepseek-chat
# DEEPSEEK_VISION_MODEL=deepseek-vl
# DEEPSEEK_TIMEOUT_SECONDS=30
# DEEPSEEK_MAX_EVENTS=30

# --- Optional OpenAI fallback (recommended OFF in scheduled runs) ---
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Optional Joinnus API bearer token ---
# Required only if Joinnus API endpoint enforces authorization.
JOINNUS_API_BEARER_TOKEN=

# --- Google Places static input (no live scraper) ---
# Path to JSON payload file with API response (default shown below):
GOOGLE_PLACES_STATIC_PATH=cultural_pipeline/input/google_places_payload.json
# Optional inline JSON payload (has priority over file path):
GOOGLE_PLACES_STATIC_PAYLOAD=

# --- Optional Places source (CSV loader) ---
# If empty, defaults to cultural_pipeline/input/google_places.csv
GOOGLE_PLACES_CSV_PATH=
